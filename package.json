    "db:migrate": "drizzle-kit migrate",
    "db:seed:demo": "tsx src/scripts/seed-demo-data.ts"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
