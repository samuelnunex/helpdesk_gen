# PostgreSQL (ex.: local, Supabase, Neon, Railway)
DATABASE_URL=postgresql://postgres:senha@localhost:5432/helpdesk

# JWT: use uma string longa e aleatória em produção (ex.: openssl rand -base64 32)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# URL pública do app (links nos e-mails de notificação), ex.: http://localhost:3005
APP_BASE_URL=http://localhost:3005

# --- E-mail de notificações (SMTP) ---
# Deixe SMTP_HOST vazio para não enviar e-mails. Use NOTIFICATION_EMAIL_ENABLED=false para forçar desligado.
NOTIFICATION_EMAIL_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
# true = SSL direto (ex.: porta 465); false = STARTTLS (ex.: 587)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Remetente exibido (obrigatório na prática para muitos provedores)
SMTP_FROM=
# Prefixo do assunto, ex.: [Helpdesk]
NOTIFICATION_EMAIL_SUBJECT_PREFIX=[Helpdesk]
